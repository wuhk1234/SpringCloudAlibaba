<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.wuhk.mapper.OrderSeataMapper">
    <resultMap id="result" type="com.wuhk.entity.OrderSeata">
        <result column="id" property="id"/>
        <result column="productId" property="productId"/>
        <result column="totalAmount" property="totalAmount"/>
        <result column="status" property="status"/>
    </resultMap>
    <insert id="creat" parameterType="com.wuhk.entity.OrderSeata">
       INSERT INTO seata_oeder_tbl (
            productId,
            totalAmount,
            status
        )
        VALUES
            (
                #{productId},
                #{totalAmount},
                #{status}
            )
    </insert>
    <select id="list" resultMap="result">
        SELECT * FROM seata_oeder_tbl
    </select>

    <select id="orderSeataById" resultType="com.wuhk.entity.OrderSeata">
        SELECT * FROM seata_oeder_tbl WHERE id = #{id}
    </select>
</mapper>
