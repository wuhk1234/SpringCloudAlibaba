<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.wuhk.mapper.UserMapper">

    <select id="findList" resultType="com.wuhk.entity.User">
        select * from t_user
    </select>
    <select id="getFindUserId" resultType="com.wuhk.entity.User">
        select * from t_user
        where 1=1
        <if test="userId != null and userId != '' ">
         and id = #{userId}
        </if>
    </select>

    <insert id="addUser" parameterType="com.wuhk.entity.User">
       INSERT INTO t_user (
            id,
            username,
            password,
            user_role
        )
        VALUES
            (
                #{id},
                #{userName},
                #{password},
                #{userRole}
            )
    </insert>
</mapper>
