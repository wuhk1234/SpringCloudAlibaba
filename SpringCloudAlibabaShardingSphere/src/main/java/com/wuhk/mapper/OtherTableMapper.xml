<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.wuhk.mapper.OtherTableMapper">
    <insert id="addOne" parameterType="com.wuhk.entity.OtherTable">
        INSERT INTO other_table(id,name) values(#{id},#{name})
    </insert>

    <select id="getAll" resultType="com.wuhk.entity.OtherTable">
         select * from other_table
    </select>

</mapper>
