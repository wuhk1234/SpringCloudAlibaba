<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.wuhk.mapper.UserMapper">
    <insert id="addOne" parameterType="com.wuhk.entity.User">
        INSERT INTO user(name,age
        <if test="userId>0">
            ,userId
        </if>
        ) values(#{name},#{age}
        <if test="userId>0">
            ,#{userId}
        </if>
        )
    </insert>

    <select id="getOneById" resultType="com.wuhk.entity.User">
         select * from user where uId=#{id}
    </select>
</mapper>
